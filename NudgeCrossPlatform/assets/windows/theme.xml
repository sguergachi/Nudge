<?xml version="1.0" encoding="utf-8"?>
<Theme xmlns="http://wixtoolset.org/schemas/v4/thm">
  <Window Width="580" Height="420" HexStyle="100a0000" />
  <Font Id="0" Height="-22" Weight="600" Foreground="FFFFFF" Background="1A1A2E" />
  <Font Id="1" Height="-12" Weight="400" Foreground="AAAAAA" Background="1A1A2E" />
  <Font Id="2" Height="-11" Weight="400" Foreground="888888" Background="1A1A2E" />
  <Font Id="3" Height="-11" Weight="400" Foreground="BB88FF" Background="1A1A2E" />
  <Font Id="4" Height="-14" Weight="600" Foreground="FFFFFF" Background="333355" />
  <Font Id="5" Height="-11" Foreground="666666" Background="1A1A2E" />

  <Page Name="Install">
    <ImageControl X="245" Y="50" Width="90" Height="90" ImageFile="nudge.png" />
    <TextControl X="40" Y="170" Width="500" Height="40" FontId="0" DisablePrefix="yes" Text="Welcome to Nudge" />
    <TextControl X="40" Y="210" Width="500" Height="20" FontId="1" DisablePrefix="yes" Text="A local AI that learns your attention patterns." />
    <ButtonControl X="190" Y="290" Width="200" Height="48" FontId="4" Name="InstallButton" Text="Install" />
    <ButtonControl X="490" Y="10" Width="80" Height="24" FontId="5" Name="CancelButton" Text="Cancel" />
  </Page>

  <Page Name="Progress">
    <TextControl X="40" Y="20" Width="500" Height="30" FontId="0" Text="Installing Nudge..." />
    <ProgressbarControl X="40" Y="70" Width="500" Height="8" />
    <TextControl X="40" Y="90" Width="500" Height="20" FontId="1" Name="OverallProgressText" />
  </Page>

  <Page Name="Finish">
    <ImageControl X="245" Y="40" Width="90" Height="90" ImageFile="nudge.png" />
    <TextControl X="40" Y="160" Width="500" Height="40" FontId="0" DisablePrefix="yes" Text="Installation Complete" />
    <TextControl X="40" Y="200" Width="500" Height="20" FontId="1" DisablePrefix="yes" Text="Nudge has been installed successfully." />
    <CheckboxControl X="40" Y="310" Width="500" Height="20" FontId="1" Name="LaunchCheckbox" Text="Launch Nudge" />
    <ButtonControl X="190" Y="340" Width="200" Height="48" FontId="4" Name="FinishButton" Text="Finish" />
  </Page>
</Theme>
